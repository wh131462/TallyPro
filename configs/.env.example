# ============================================================
# TallyPro 统一环境变量配置
# 复制本文件为 .env 并填写实际值
# ============================================================

# ---- Server ----
PORT=8866
NODE_ENV=development

# ---- Database (MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tally_pro
DB_USER=root
DB_PASSWORD=

# ---- 微信小程序 ----
WX_APP_ID=
WX_APP_SECRET=

# ---- JWT ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ---- 管理员密码（反馈管理）----
ADMIN_PASSWORD=

# ---- App (Vite, VITE_ 前缀变量会注入前端) ----
VITE_API_BASE_URL=http://localhost:8866/api
