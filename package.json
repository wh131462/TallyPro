{
  "name": "tally-pro",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:app": "pnpm -C packages/app dev:mp-weixin",
    "dev:h5": "pnpm -C packages/app dev:h5",
    "dev:server": "pnpm -C packages/server dev",
    "build:app": "pnpm -C packages/app build:mp-weixin",
    "build:server": "pnpm -C packages/server build",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:stop": "docker-compose stop",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:mysql": "docker-compose logs -f mysql",
    "docker:logs:redis": "docker-compose logs -f redis",
    "docker:ps": "docker-compose ps",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "docker:mysql": "docker exec -it tally-pro-mysql mysql -uroot -ptally_pro_root tally_pro",
    "docker:redis": "docker exec -it tally-pro-redis redis-cli"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
